<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Private Studio Pro</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:#0f172a;
    color:white;
    padding:20px;
}

h1{margin-bottom:5px;}
p{color:#94a3b8;}

.container{
    display:grid;
    grid-template-columns:320px 1fr;
    gap:20px;
    margin-top:20px;
}

.panel{
    background:#1e293b;
    padding:15px;
    border-radius:12px;
}

input,textarea,select{
    width:100%;
    padding:10px;
    margin:8px 0 12px;
    border-radius:8px;
    border:none;
    background:#334155;
    color:white;
}

button{
    width:100%;
    padding:10px;
    border:none;
    border-radius:8px;
    background:#3b82f6;
    color:white;
    font-weight:bold;
    cursor:pointer;
}

button:hover{background:#2563eb;}

.catalog{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
    gap:15px;
}

.card{
    background:#1e293b;
    border-radius:12px;
    overflow:hidden;
}

video{
    width:100%;
    max-height:200px;
    background:black;
}

.card-content{
    padding:10px;
}

.tag{
    background:#22c55e;
    display:inline-block;
    padding:4px 8px;
    border-radius:999px;
    font-size:12px;
    margin-bottom:5px;
}

.ep{
    background:#334155;
    padding:8px;
    border-radius:8px;
    margin-top:8px;
    font-size:13px;
}

.delete{
    background:#ef4444;
    margin-top:8px;
}
</style>
</head>
<body>

<h1>🎬 Private Studio Pro</h1>
<p>Everything is stored locally using IndexedDB (supports bigger files).</p>

<div class="container">

<div class="panel">
<h3>Create</h3>

<select id="type">
<option value="movie">Movie</option>
<option value="show">Show</option>
</select>

<input id="title" placeholder="Title">
<textarea id="desc" placeholder="Description"></textarea>

<input type="file" id="video" accept="video/*">

<div id="showBox" style="display:none;">
<input id="season" type="number" placeholder="Season">
<input id="episode" type="number" placeholder="Episode">
<input id="epTitle" placeholder="Episode Title">
</div>

<button onclick="save()">Save</button>
</div>

<div>
<h3>Your Catalog</h3>
<div class="catalog" id="catalog"></div>
</div>

</div>

<script>
// ---------------- INDEXEDDB SETUP ----------------
let db;

const request = indexedDB.open("studioDB", 1);

request.onupgradeneeded = e => {
    db = e.target.result;
    db.createObjectStore("videos", { keyPath: "id" });
};

request.onsuccess = e => {
    db = e.target.result;
    load();
};

// ---------------- UI ----------------
document.getElementById("type").onchange = e => {
    document.getElementById("showBox").style.display =
        e.target.value === "show" ? "block" : "none";
};

// ---------------- SAVE ----------------
function save(){
    const file = document.getElementById("video").files[0];
    if(!file) return alert("Add video");

    const reader = new FileReader();

    reader.onload = function(){
        const data = {
            id: Date.now(),
            type: type.value,
            title: title.value,
            desc: desc.value,
            video: reader.result
        };

        if(type.value === "show"){
            data.season = season.value;
            data.episode = episode.value;
            data.epTitle = epTitle.value;
        }

        const tx = db.transaction("videos","readwrite");
        tx.objectStore("videos").put(data);

        tx.oncomplete = () => {
            load();
            alert("Saved!");
        };
    };

    reader.readAsDataURL(file);
}

// ---------------- LOAD ----------------
function load(){
    const tx = db.transaction("videos","readonly");
    const store = tx.objectStore("videos");

    const req = store.getAll();

    req.onsuccess = () => {
        render(req.result);
    };
}

// ---------------- DELETE ----------------
function del(id){
    const tx = db.transaction("videos","readwrite");
    tx.objectStore("videos").delete(id);
    tx.oncomplete = load;
}

// ---------------- RENDER ----------------
function render(items){
    const box = document.getElementById("catalog");
    box.innerHTML = "";

    if(items.length === 0){
        box.innerHTML = "<p>No content yet.</p>";
        return;
    }

    items.reverse().forEach(i => {

        const div = document.createElement("div");
        div.className = "card";

        div.innerHTML = `
            <video controls src="${i.video}"></video>
            <div class="card-content">
                <div class="tag">${i.type.toUpperCase()}</div>
                <h3>${i.title}</h3>
                <p>${i.desc}</p>

                ${i.type==="show" ? `
                <div class="ep">
                    Season ${i.season} • Episode ${i.episode}<br>
                    ${i.epTitle || ""}
                </div>` : ""}

                <button class="delete" onclick="del(${i.id})">Delete</button>
            </div>
        `;

        box.appendChild(div);
    });
}
</script>

</body>
</html>
